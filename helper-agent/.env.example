AGENT_PORT=17357
APP_ORIGIN=http://localhost:5173

# Path to the PKCS#11 library for your smart card.
# On Windows, if left empty, the agent tries to auto-detect common middleware DLLs.
#
# Windows (set if auto-detection fails):
#   SafeNet eToken (Evrotrust, Info Notary): C:\Windows\System32\eTPkcs11.dll
#   B-Trust / Bit4id:                        C:\Windows\System32\bit4ipki.dll
#   OpenSC (generic):                        C:\Windows\System32\opensc-pkcs11.dll
#
# Linux:
#   SafeNet eToken: /usr/lib64/libeTPkcs11.so
#   OpenSC:         /usr/lib64/opensc-pkcs11.so
#   SoftHSM2:       /usr/lib64/softhsm/libsofthsm2.so
PKCS11_LIB=

# Index of the token slot (0 = first slot with a token present)
PKCS11_SLOT=0

# User PIN (optional — if absent the user is prompted via OS dialog at sign-time).
# On Windows: masked WinForms dialog (PowerShell 5.1+)
# On Linux:   pinentry → zenity → kdialog → terminal
# Never set this in production; it is only for automated testing.
PKCS11_PIN=
