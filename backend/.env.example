PORT=4000
UPLOAD_DIR=./uploads
DOWNLOAD_TOKEN_SECRET=change-me-to-a-random-secret
DOWNLOAD_TOKEN_TTL_SECONDS=3600
FRONTEND_ORIGIN=http://localhost:5173

# Supabase (Phase 2´ — auth + credits)
# Project URL, e.g. https://abcdefgh.supabase.co — used to fetch the JWKS
# for verifying user JWTs.
SUPABASE_URL=
# Legacy HS256 JWT secret (Supabase dashboard → Settings → API). Only needed
# for older projects that don't use asymmetric signing keys; leave empty
# otherwise.
SUPABASE_JWT_SECRET=

# Database (Prisma) — Supabase Postgres.
# DATABASE_URL: transaction-mode pooler (port 6543, pgbouncer=true) — runtime.
# DIRECT_URL:   session-mode pooler (port 5432) — used by prisma migrate.
# Both from Supabase Dashboard → Connect → ORMs → Prisma.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Stripe (Phase 2´ milestone 2 — credit packages + business subscriptions)
# Dashboard → Developers → API keys (sk_test_... until go-live).
STRIPE_SECRET_KEY=
# Webhook endpoint signing secret (whsec_...). In local dev use the one
# printed by: stripe listen --forward-to localhost:4000/api/billing/webhook
STRIPE_WEBHOOK_SECRET=
# Price IDs from Dashboard → Product catalog (price_..., NOT prod_...).
STRIPE_PRICE_CREDITS_50=
STRIPE_PRICE_BUSINESS_MONTHLY=

# Cloud signing providers (Phase 3+ — on hold)
# TODO: fill from Evrotrust partner account
EVROTRUST_API_URL=https://api.evrotrust.eu
EVROTRUST_API_KEY=
EVROTRUST_PARTNER_ID=

# TODO: fill from B-Trust partner account
BTRUST_API_URL=https://api.btrust.bg
BTRUST_API_KEY=
